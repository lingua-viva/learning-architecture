{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TeacherLens",
  "type": "object",
  "required": ["teacher_id", "grading_calibration", "differentiation_style", "communication_voice", "assessment_weighting", "ingested_doc_count", "last_updated", "source_documents"],
  "properties": {
    "teacher_id": {"type": "string", "minLength": 1},
    "grading_calibration": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["weight", "examples"],
        "properties": {
          "weight": {"type": "number", "minimum": 0, "maximum": 1},
          "examples": {"type": "array", "minItems": 1}
        }
      }
    },
    "differentiation_style": {
      "type": "object",
      "required": ["foundational", "on_track", "extended"],
      "additionalProperties": {
        "type": "object",
        "properties": {
          "scaffolding": {"type": "array"},
          "extensions": {"type": "array"}
        }
      }
    },
    "communication_voice": {
      "type": "object",
      "required": ["formality", "l1_l2_ratio", "focus_areas"],
      "properties": {
        "formality": {"type": "string"},
        "l1_l2_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "focus_areas": {"type": "array", "items": {"type": "string"}}
      }
    },
    "assessment_weighting": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "pacing_style": {"type": "object"},
    "ingested_doc_count": {"type": "integer", "minimum": 0},
    "last_updated": {"type": "string", "format": "date-time"},
    "source_documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc_id", "type", "ingested_at"],
        "properties": {
          "doc_id": {"type": "string"},
          "type": {"type": "string"},
          "ingested_at": {"type": "string"}
        }
      }
    }
  }
}
