{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rubric",
  "type": "object",
  "required": ["rubric_id", "criteria", "levels"],
  "properties": {
    "rubric_id": {"type": "string", "minLength": 1},
    "unit_id": {"type": "string"},
    "grade": {"type": "string"},
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "levels"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "weight": {"type": "number"},
          "levels": {
            "type": "object",
            "minProperties": 2,
            "additionalProperties": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "levels": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string"}
    }
  }
}
